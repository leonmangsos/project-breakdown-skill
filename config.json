  "maxTaskHistory": 100,
  "backupOnSave": true,
  "backupRetentionDays": 7,
  "projectDirectory": ".workbuddy/project-breakdown",
  "maxActiveProjects": 1,
  "enableAutoIntervention": true,
  "interventionConfidence": 0.8,
  "triggerKeywords": {
    "newProject": [
      "创建",
      "开发",
      "新建",
      "开始",
      "搭建",
      "构建",
      "实现",
      "制作",
      "做一个",
      "我要做",
      "我想做",
      "帮我做"
    ],
    "queryStatus": [
      "进度",
      "状态",
      "任务",
      "完成",
      "进展",
      "情况",
      "怎么样",
      "如何",
      "下一步"
    ],
    "modifyRequest": [
      "修改",
      "增加",
      "调整",
      "删除",
      "更新",
      "改变",
      "优化",
      "改进",
      "扩展"
    ],
    "reviewProject": [
      "之前",
      "刚才",
      "回顾",
      "查看",
      "需求",
      "项目"
    ],
    "continueProject": [
      "继续",
      "接下来",
      "然后",
      "下一步",
      "接着"
    ]

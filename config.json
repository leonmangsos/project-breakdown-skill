  "taskPriorities": {
    "critical": {
      "weight": 5,
      "color": "#dc3545",
      "description": "阻塞性任务，必须立即处理"
    },
    "high": {
      "weight": 4,
      "color": "#fd7e14",
      "description": "高优先级任务，优先处理"
    },
    "medium": {
      "weight": 3,
      "color": "#ffc107",
      "description": "中等优先级，按计划执行"
    },
    "low": {
      "weight": 2,
      "color": "#28a745",
      "description": "低优先级，有时间再处理"
    }
  },
  "taskCategories": {
    "setup": {
      "displayName": "基础设施",
      "icon": "🔧",
      "defaultPriority": "critical"
    },
    "core-feature": {
      "displayName": "核心功能",
      "icon": "⭐",
      "defaultPriority": "high"
    },
    "enhancement": {
      "displayName": "功能增强",
      "icon": "✨",
      "defaultPriority": "medium"
    },
    "bugfix": {
      "displayName": "Bug修复",
      "icon": "🐛",
      "defaultPriority": "high"
    },
    "testing": {
      "displayName": "测试",
      "icon": "🧪",
      "defaultPriority": "high"
    },
    "docs": {
      "displayName": "文档",
      "icon": "📚",
      "defaultPriority": "low"
    },
    "deployment": {
      "displayName": "部署",
      "icon": "🚀",
      "defaultPriority": "medium"
    }
  },
  "taskStatusFlow": [
    "pending",
    "in-progress",
    "completed",
    "blocked"
  ],
  "performance": {
    "enableCaching": true,
    "cacheExpiry": 3600,
    "lazyLoading": true,
    "batchUpdates": true,
    "compressLogs": true
  },
  "integration": {
    "enableGitIntegration": false,
    "enableCIIntegration": false,
    "enableExternalTools": false,
    "supportedExternalTools": []
